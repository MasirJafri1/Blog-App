<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/Head') %>
        <title>
            <%= blog.title %>
        </title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>

<body>
    <%- include('./partials/Nav') %>

        <div class="blog-container">
            <div class="blog-cover-wrapper">
                <img class="blog-cover" src="<%= blog.coverImageUrl %>" alt="<%= blog.title %>">
            </div>

            <h1 class="blog-title">
                <%= blog.title %>
            </h1>

            <div class="author-info">
                <img class="author-image" src="<%= blog.createdBy.profileImageURL %>"
                    alt="<%= blog.createdBy.fullName %>">
                <span class="author-name">
                    <%= blog.createdBy.fullName %>
                </span>
            </div>

            <div class="blog-content">
                <%= blog.body %>
            </div>

            <section class="comments-section">
                <h2 class="comments-title">Comments (<%= comments.length %>)</h2>

                <% if (locals.user) { %>
                    <form class="comment-form" action="/blog/comment/<%= blog._id %>" method="post">
                        <input type="text" class="comment-input" name="content" placeholder="Write your comment...">
                        <button class="comment-btn" type="submit">Add Comment</button>
                    </form>
                    <% } %>

                        <div class="comments-list">
                            <% comments.forEach(comment=> { %>
                                <div class="comment">
                                    <div class="comment-author">
                                        <% if (comment.createdBy) { %>
                                            <img src="<%= comment.createdBy.profileImageURL %>"
                                                alt="<%= comment.createdBy.fullName %>">
                                            <span>
                                                <%= comment.createdBy.fullName %>
                                            </span>
                                            <% } else { %>
                                                <span>Anonymous User</span>
                                                <% } %>
                                    </div>
                                    <div class="comment-content">
                                        <%= comment.content %>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
            </section>
        </div>

        <style>
            body {
                background: #1a1f2c;
                color: #fff;
                font-family: 'Inter', sans-serif;
                line-height: 1.6;
                margin: 0;
            }

            .blog-container {
                max-width: 800px;
                margin: 2rem auto;
                padding: 0 1.5rem;
            }

            .blog-cover-wrapper {
                margin: -1.5rem -1.5rem 2rem;
                position: relative;
            }

            .blog-cover {
                width: 100%;
                height: 400px;
                object-fit: cover;
            }

            .blog-title {
                font-size: 2rem;
                font-weight: 700;
                margin: 1.5rem 0;
                color: #fff;
                line-height: 1.3;
            }

            .author-info {
                display: flex;
                align-items: center;
                gap: 1rem;
                margin: 1rem 0 2rem;
                padding: 1rem;
                background: rgba(255, 255, 255, 0.05);
                border-radius: 8px;
            }

            .author-image {
                width: 45px;
                height: 45px;
                border-radius: 50%;
                object-fit: cover;
                border: 2px solid #64ffda;
            }

            .author-name {
                color: #64ffda;
                font-size: 0.9rem;
                font-weight: 500;
            }

            .blog-content {
                font-size: 1.05rem;
                line-height: 1.8;
                color: rgba(255, 255, 255, 0.9);
                margin: 2rem 0;
                white-space: pre-wrap;
            }

            /* Comments Section */
            .comments-section {
                margin-top: 3rem;
                padding-top: 2rem;
                border-top: 1px solid rgba(255, 255, 255, 0.1);
            }

            .comments-title {
                font-size: 1.2rem;
                color: #64ffda;
                margin-bottom: 1.5rem;
            }

            .comment-form {
                margin-bottom: 2rem;
            }

            .comment-input {
                width: 100%;
                padding: 0.8rem 1rem;
                background: rgba(255, 255, 255, 0.05);
                border: 1px solid rgba(255, 255, 255, 0.1);
                border-radius: 6px;
                color: #fff;
                font-size: 0.95rem;
                margin-bottom: 1rem;
                transition: all 0.3s ease;
            }

            .comment-input:focus {
                outline: none;
                border-color: #64ffda;
                background: rgba(255, 255, 255, 0.08);
            }

            .comment-btn {
                padding: 0.7rem 1.2rem;
                background: #64ffda;
                color: #1a1f2c;
                border: none;
                border-radius: 6px;
                font-weight: 500;
                font-size: 0.9rem;
                cursor: pointer;
                transition: all 0.3s ease;
            }

            .comment-btn:hover {
                background: #73ffde;
                transform: translateY(-1px);
            }

            .comment {
                padding: 1rem;
                margin-bottom: 1rem;
                background: rgba(255, 255, 255, 0.03);
                border-radius: 8px;
                transition: all 0.3s ease;
            }

            .comment:hover {
                background: rgba(255, 255, 255, 0.05);
            }

            .comment-author {
                display: flex;
                align-items: center;
                gap: 0.8rem;
                margin-bottom: 0.8rem;
            }

            .comment-author img {
                width: 35px;
                height: 35px;
                border-radius: 50%;
                border: 1px solid rgba(100, 255, 218, 0.3);
            }

            .comment-content {
                color: rgba(255, 255, 255, 0.8);
                font-size: 0.95rem;
                margin-left: 3.2rem;
                line-height: 1.6;
            }

            @media (max-width: 768px) {
                .blog-container {
                    margin: 1rem auto;
                }

                .blog-cover {
                    height: 300px;
                }

                .blog-title {
                    font-size: 1.8rem;
                }

                .blog-content {
                    font-size: 1rem;
                }
            }

            @media (max-width: 480px) {
                .blog-cover {
                    height: 200px;
                }

                .blog-title {
                    font-size: 1.5rem;
                }

                .author-info {
                    flex-direction: column;
                    text-align: center;
                    padding: 0.8rem;
                }
            }
        </style>

        <%- include('./partials/Footer') %>
            <%- include('./partials/Scripts') %>
</body>

</html>